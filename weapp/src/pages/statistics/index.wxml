<view class="page">
  <!-- 概览卡片 -->
  <view class="overview">
    <view class="overview__item">
      <text class="overview__label">活跃订阅</text>
      <text class="overview__value">{{activeCount}}</text>
    </view>
    <view class="overview__divider"></view>
    <view class="overview__item">
      <text class="overview__label">月均支出</text>
      <view class="overview__amount">
        <text class="overview__currency">{{currencySymbol}}</text>
        <text class="overview__value">{{monthlyTotalDisplay}}</text>
      </view>
    </view>
    <view class="overview__divider"></view>
    <view class="overview__item">
      <text class="overview__label">年度支出</text>
      <view class="overview__amount">
        <text class="overview__currency">{{currencySymbol}}</text>
        <text class="overview__value">{{yearlyTotalDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tabs">
    <view
      class="tabs__item {{selectedTab === 'category' ? 'tabs__item--active' : ''}}"
      data-tab="category"
      bindtap="switchTab"
    >
      <text>分类统计</text>
    </view>
    <view
      class="tabs__item {{selectedTab === 'currency' ? 'tabs__item--active' : ''}}"
      data-tab="currency"
      bindtap="switchTab"
    >
      <text>货币分布</text>
    </view>
    <view
      class="tabs__item {{selectedTab === 'trend' ? 'tabs__item--active' : ''}}"
      data-tab="trend"
      bindtap="switchTab"
    >
      <text>支出趋势</text>
    </view>
  </view>

  <!-- 分类统计 -->
  <view wx:if="{{selectedTab === 'category'}}" class="chart-section">
    <view wx:if="{{categoryData.length > 0}}" class="chart-container">
      <canvas type="2d" id="pie-chart" class="chart-canvas"></canvas>
    </view>

    <!-- 分类列表 -->
    <view class="category-list">
      <view wx:for="{{categoryData}}" wx:key="name" class="category-item">
        <view class="category-item__color" style="background-color: {{item.color}}"></view>
        <text class="category-item__name">{{item.name}}</text>
        <text class="category-item__value">{{currencySymbol}}{{item.value}}</text>
        <text class="category-item__percent">{{item.percentage}}%</text>
      </view>
    </view>
  </view>

  <!-- 货币分布 -->
  <view wx:if="{{selectedTab === 'currency'}}" class="currency-section">
    <view wx:if="{{currencyData.length === 0}}" class="empty-state">
      <text>暂无数据</text>
    </view>
    <view wx:else class="currency-list">
      <view wx:for="{{currencyData}}" wx:key="currency" class="currency-item">
        <view class="currency-item__header">
          <text class="currency-item__symbol">{{item.currency === 'CNY' ? '¥' : item.currency === 'USD' ? '$' : item.currency === 'EUR' ? '€' : item.currency === 'GBP' ? '£' : item.currency === 'JPY' ? '¥' : item.currency === 'HKD' ? 'HK$' : 'NT$'}}</text>
          <text class="currency-item__name">{{item.currency}}</text>
          <text class="currency-item__count">{{item.count}} 个订阅</text>
        </view>
        <view class="currency-item__amounts">
          <view class="currency-item__amount">
            <text class="currency-item__label">月均</text>
            <text class="currency-item__value">{{item.monthlyDisplay}}</text>
          </view>
          <view class="currency-item__amount">
            <text class="currency-item__label">年度</text>
            <text class="currency-item__value">{{item.yearlyDisplay}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 支出趋势 -->
  <view wx:if="{{selectedTab === 'trend'}}" class="chart-section">
    <view class="chart-header">
      <text class="chart-title">{{currentYear}}年月度支出</text>
    </view>
    <view class="chart-container chart-container--tall">
      <canvas type="2d" id="trend-chart" class="chart-canvas"></canvas>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{activeCount === 0}}" class="empty-state full">
    <text class="empty-state__icon">📊</text>
    <text class="empty-state__title">暂无统计数据</text>
    <text class="empty-state__desc">添加订阅后可查看统计分析</text>
  </view>
</view>
