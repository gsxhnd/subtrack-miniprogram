<view class="page">
  <!-- 订阅概览 -->
  <view class="overview-card">
    <view class="overview-card__row">
      <view class="overview-card__item">
        <text class="overview-card__label">活跃订阅</text>
        <text class="overview-card__value">{{activeCount}} 个</text>
      </view>
      <view class="overview-card__item">
        <text class="overview-card__label">已取消</text>
        <text class="overview-card__value">{{cancelledCount}} 个</text>
      </view>
    </view>
    <view class="overview-card__divider"></view>
    <view class="overview-card__row">
      <view class="overview-card__item">
        <text class="overview-card__label">月度支出</text>
        <view class="overview-card__amount">
          <text class="overview-card__currency">{{currencySymbol}}</text>
          <text class="overview-card__value overview-card__value--amount">{{monthlySpendingDisplay}}</text>
        </view>
      </view>
      <view class="overview-card__item">
        <text class="overview-card__label">年度支出</text>
        <view class="overview-card__amount">
          <text class="overview-card__currency">{{currencySymbol}}</text>
          <text class="overview-card__value overview-card__value--amount">{{yearlySpendingDisplay}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="section">
    <text class="section__title">通用设置</text>
    <view class="section__list">
      <view class="section__item" bindtap="goToBudgetSettings">
        <text class="section__item-label">月度预算</text>
        <view class="section__item-right">
          <text class="section__item-value">{{budgetDisplay}}</text>
          <text class="section__item-arrow">›</text>
        </view>
      </view>
      <view class="section__item" bindtap="goToExchangeRate">
        <text class="section__item-label">汇率设置</text>
        <view class="section__item-right">
          <text class="section__item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section">
    <text class="section__title">数据管理</text>
    <view class="section__list">
      <view class="section__item" bindtap="handleClearData">
        <text class="section__item-label section__item-label--danger">清除所有数据</text>
        <view class="section__item-right">
          <text class="section__item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <text class="section__title">关于</text>
    <view class="section__list">
      <view class="section__item">
        <text class="section__item-label">版本</text>
        <view class="section__item-right">
          <text class="section__item-value">v{{appVersion}}</text>
        </view>
      </view>
      <view class="section__item" bindtap="handleFeedback">
        <text class="section__item-label">意见反馈</text>
        <view class="section__item-right">
          <text class="section__item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
