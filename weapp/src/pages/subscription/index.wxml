<view class="page">
  <!-- 标签栏 -->
  <view class="tabs">
    <view
      class="tabs__item {{currentTab === 'active' ? 'tabs__item--active' : ''}}"
      data-tab="active"
      bindtap="switchTab"
    >
      <text class="tabs__label">有效订阅</text>
      <text class="tabs__count">{{activeSubscriptions.length}}</text>
    </view>
    <view
      class="tabs__item {{currentTab === 'cancelled' ? 'tabs__item--active' : ''}}"
      data-tab="cancelled"
      bindtap="switchTab"
    >
      <text class="tabs__label">已取消</text>
      <text class="tabs__count">{{cancelledSubscriptions.length}}</text>
    </view>
  </view>

  <!-- 排序和筛选工具栏 -->
  <view wx:if="{{currentTab === 'active'}}" class="toolbar">
    <view class="toolbar__btn" bindtap="showSortOptions">
      <text class="toolbar__icon">⇅</text>
      <text class="toolbar__text">{{sortType === 'date' ? '按日期' : sortType === 'amount' ? '按金额' : '按名称'}}</text>
      <text class="toolbar__arrow">▼</text>
    </view>
    <view class="toolbar__btn" bindtap="showFilterOptions">
      <text class="toolbar__icon">◉</text>
      <text class="toolbar__text">筛选</text>
      <text wx:if="{{filterCurrency !== 'all' || filterCategory !== 'all'}}" class="toolbar__badge">•</text>
      <text class="toolbar__arrow">▼</text>
    </view>
  </view>

  <!-- 订阅列表 -->
  <view class="list">
    <block wx:if="{{currentTab === 'active'}}">
      <SubscriptionCard
        wx:for="{{activeSubscriptions}}"
        wx:key="id"
        subscription="{{item}}"
        bind:tap="goToDetail"
        bind:edit="goToEdit"
      />
    </block>
    <block wx:else>
      <SubscriptionCard
        wx:for="{{cancelledSubscriptions}}"
        wx:key="id"
        subscription="{{item}}"
        showStatus="{{true}}"
        bind:tap="goToDetail"
        bind:edit="goToEdit"
      />
    </block>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{(currentTab === 'active' && activeSubscriptions.length === 0) || (currentTab === 'cancelled' && cancelledSubscriptions.length === 0)}}" class="empty-state">
    <text>{{currentTab === 'active' ? '暂无有效订阅' : '暂无已取消订阅'}}</text>
  </view>

  <!-- 排序选择弹窗 -->
  <view wx:if="{{showSortPicker}}" class="picker-overlay" bindtap="closeSortPicker">
    <view class="picker picker--bottom" catchtap="">
      <view class="picker__header">
        <text class="picker__title">排序方式</text>
        <view class="picker__close" bindtap="closeSortPicker">✕</view>
      </view>
      <view class="picker__list">
        <view
          class="picker__item {{sortType === 'date' ? 'picker__item--active' : ''}}"
          data-type="date"
          bindtap="onSortTypeChange"
        >
          <text class="picker__item-label">按扣款日期</text>
          <text wx:if="{{sortType === 'date'}}" class="picker__item-order">{{sortOrder === 'asc' ? '↑' : '↓'}}</text>
        </view>
        <view
          class="picker__item {{sortType === 'amount' ? 'picker__item--active' : ''}}"
          data-type="amount"
          bindtap="onSortTypeChange"
        >
          <text class="picker__item-label">按金额</text>
          <text wx:if="{{sortType === 'amount'}}" class="picker__item-order">{{sortOrder === 'asc' ? '↑' : '↓'}}</text>
        </view>
        <view
          class="picker__item {{sortType === 'name' ? 'picker__item--active' : ''}}"
          data-type="name"
          bindtap="onSortTypeChange"
        >
          <text class="picker__item-label">按名称</text>
          <text wx:if="{{sortType === 'name'}}" class="picker__item-order">{{sortOrder === 'asc' ? '↑' : '↓'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选选择弹窗 -->
  <view wx:if="{{showFilterPicker}}" class="picker-overlay" bindtap="closeFilterPicker">
    <view class="picker picker--bottom" catchtap="">
      <view class="picker__header">
        <text class="picker__title">筛选</text>
        <view class="picker__close" bindtap="closeFilterPicker">✕</view>
      </view>

      <!-- 货币筛选 -->
      <view class="filter-section">
        <text class="filter-section__title">货币</text>
        <view class="filter-section__options">
          <view
            wx:for="{{currencyOptions}}"
            wx:key="value"
            class="filter-chip {{filterCurrency === item.value ? 'filter-chip--active' : ''}}"
            data-currency="{{item.value}}"
            bindtap="onFilterCurrencyChange"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 分类筛选 -->
      <view wx:if="{{categories.length > 0}}" class="filter-section">
        <text class="filter-section__title">分类</text>
        <view class="filter-section__options">
          <view
            class="filter-chip {{filterCategory === 'all' ? 'filter-chip--active' : ''}}"
            data-category="all"
            bindtap="onFilterCategoryChange"
          >
            <text>全部分类</text>
          </view>
          <view
            wx:for="{{categories}}"
            wx:key="*this"
            class="filter-chip {{filterCategory === item ? 'filter-chip--active' : ''}}"
            data-category="{{item}}"
            bindtap="onFilterCategoryChange"
          >
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 重置按钮 -->
      <view class="filter-actions">
        <view class="filter-actions__reset" bindtap="resetFilter">重置筛选</view>
      </view>
    </view>
  </view>
</view>
