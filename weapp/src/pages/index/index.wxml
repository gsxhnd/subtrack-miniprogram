<view class="page">
  <!-- 预算进度卡片 -->
  <BudgetProgress
    spent="{{monthlySpending}}"
    budget="{{monthlyBudget}}"
    progress="{{budgetProgress}}"
    status="{{budgetStatus}}"
    currency="{{baseCurrency}}"
    bind:tap="goToBudgetSettings"
  />

  <!-- 费用统计卡片 -->
  <view class="stats-card">
    <view class="stats-card__item" bindtap="goToStatistics">
      <text class="stats-card__label">月均支出</text>
      <view class="stats-card__value">
        <text class="stats-card__currency">{{currencySymbol}}</text>
        <text class="stats-card__amount">{{monthlySpendingDisplay}}</text>
      </view>
    </view>
    <view class="stats-card__divider"></view>
    <view class="stats-card__item" bindtap="goToStatistics">
      <text class="stats-card__label">年度支出</text>
      <view class="stats-card__value">
        <text class="stats-card__currency">{{currencySymbol}}</text>
        <text class="stats-card__amount">{{yearlySpendingDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- 即将续费列表 -->
  <view class="upcoming-section">
    <view class="upcoming-section__header">
      <text class="upcoming-section__title">即将续费</text>
      <text class="upcoming-section__count">{{upcomingRenewals.length}}</text>
    </view>

    <view wx:if="{{upcomingRenewals.length === 0}}" class="upcoming-section__empty">
      <text>暂无即将续费的订阅</text>
    </view>

    <view wx:else class="upcoming-section__list">
      <view
        wx:for="{{upcomingRenewals}}"
        wx:key="id"
        class="upcoming-item"
        data-id="{{item.id}}"
        bindtap="goToSubscriptionDetail"
      >
        <view class="upcoming-item__icon">
          <text>{{item.name[0]}}</text>
        </view>
        <view class="upcoming-item__content">
          <text class="upcoming-item__name">{{item.name}}</text>
          <text class="upcoming-item__date">{{item.nextBillingDate}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view>
    <view class="empty-state__icon">📊</view>
    <text class="empty-state__title">还没有订阅</text>
    <text class="empty-state__desc">点击底部 + 按钮添加你的第一个订阅</text>
  </view>
</view>
