<view class="page">
  <view class="form">
    <!-- 预算金额 -->
    <view class="form-item">
      <text class="form-item__label">月度预算</text>
      <view class="form-item__row">
        <input
          class="form-item__input"
          type="digit"
          placeholder="输入月度预算"
          value="{{budgetInYuan}}"
          bindinput="onBudgetInput"
        />
        <picker mode="selector" range="{{['CNY', 'USD', 'EUR', 'GBP', 'JPY', 'HKD', 'TWD']}}" bindchange="onCurrencyChange">
          <view class="form-item__select">
            <text>{{baseCurrency}}</text>
            <text class="form-item__arrow">▼</text>
          </view>
        </picker>
      </view>
      <text class="form-item__hint">设置每月的订阅支出预算上限</text>
    </view>
  </view>

  <!-- 汇率设置入口 -->
  <view class="link-item" bindtap="goToExchangeRate">
    <view class="link-item__content">
      <text class="link-item__icon">💱</text>
      <view class="link-item__text">
        <text class="link-item__title">汇率设置</text>
        <text class="link-item__desc">设置外币转换汇率</text>
      </view>
    </view>
    <text class="link-item__arrow">›</text>
  </view>

  <!-- 提示信息 -->
  <view class="tips">
    <text class="tips__title">💡 提示</text>
    <text class="tips__content">设置预算后，首页会显示预算进度条。当支出接近或超过预算时，会以不同颜色提醒。</text>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="handleSave">保存设置</button>
</view>
