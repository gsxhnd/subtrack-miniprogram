<view class="tab-bar">
  <!-- 圆形遮罩 - 形成中间凹陷效果 -->
  <view class="tab-bar__notch"></view>

  <!-- 左区域: 首页、订阅 -->
  <view class="tab-bar__left">
    <view
      class="tab-bar__item"
      data-path="{{list[0].pagePath}}"
      data-index="{{0}}"
      bindtap="switchTab"
    >
      <image class="tab-bar__icon" src="{{selected === 0 ? list[0].selectedIcon : list[0].icon}}" />
      <text class="tab-bar__label tab-bar__label--{{selected === 0 ? 'active' : ''}}">{{list[0].text}}</text>
    </view>
    <view
      class="tab-bar__item"
      data-path="{{list[1].pagePath}}"
      data-index="{{1}}"
      bindtap="switchTab"
    >
      <image class="tab-bar__icon" src="{{selected === 1 ? list[1].selectedIcon : list[1].icon}}" />
      <text class="tab-bar__label tab-bar__label--{{selected === 1 ? 'active' : ''}}">{{list[1].text}}</text>
    </view>
  </view>

  <!-- 中间区域: + 按钮 -->
  <view class="tab-bar__center">
    <view 
      class="tab-bar__add-btn {{addPressed ? 'tab-bar__add-btn--active' : ''}}" 
      bindtap="onAdd"
      bindtouchstart="onAddTouchStart"
      bindtouchend="onAddTouchEnd"
      bindtouchcancel="onAddTouchEnd"
    >
      <text class="tab-bar__add-icon">+</text>
    </view>
  </view>

  <!-- 右区域: 统计、我的 -->
  <view class="tab-bar__right">
    <view
      class="tab-bar__item"
      data-path="{{list[2].pagePath}}"
      data-index="{{2}}"
      bindtap="switchTab"
    >
      <image class="tab-bar__icon" src="{{selected === 2 ? list[2].selectedIcon : list[2].icon}}" />
      <text class="tab-bar__label tab-bar__label--{{selected === 2 ? 'active' : ''}}">{{list[2].text}}</text>
    </view>
    <view
      class="tab-bar__item"
      data-path="{{list[3].pagePath}}"
      data-index="{{3}}"
      bindtap="switchTab"
    >
      <image class="tab-bar__icon" src="{{selected === 3 ? list[3].selectedIcon : list[3].icon}}" />
      <text class="tab-bar__label tab-bar__label--{{selected === 3 ? 'active' : ''}}">{{list[3].text}}</text>
    </view>
  </view>
</view>
